    <a href="{{ routes.search_url }}" aria-label="Search" class="nav-icon-link">Search</a>
    <a href="{{ routes.cart_url }}" aria-label="Cart" class="nav-icon-link">
      Cart{%- if cart.item_count > 0 -%} ({{ cart.item_count }}){%- endif -%}
    </a>
    <a href="#pricing" class="nav-cta">Order Now â</a>
  </div>
</nav>

<!-- HERO -->
<section class="hero">
  <div class="hero-glow"></div>
  <div class="hero-kicker animate-fade">
    <span class="hero-kicker-dot"></span>
    AI-Powered Fashion Photography
  </div>
  <h1 class="animate-fade d-1">
    Your Products.<br /><span>Worn by AI Models.</span>
  </h1>
  <p class="hero-sub animate-fade d-2">
    Upload a white-background product photo. Choose from 20 diverse AI models.
    Get back professional model photos in 3 business days â starting at $6.
  </p>
  <div class="hero-actions animate-fade d-3">
    <a href="#pricing" class="btn-primary">Get Started â $6/image â</a>
    <a href="#models" class="btn-secondary">View AI Models</a>
  </div>

  <!-- Before / After Showcase -->
  <div class="showcase animate-fade d-4">
    <div class="showcase-card">
      <span class="showcase-label label-before">Before</span>
      <div class="showcase-img-before">
        ð
      </div>
    </div>
    <div class="showcase-arrow">â</div>
    <div class="showcase-card">
      <span class="showcase-label label-after">After</span>
      <div class="showcase-img-after">
        <div class="showcase-model-silhouette"></div>
        <span class="showcase-days">3 Business Days</span>
      </div>
    </div>
  </div>
</section>

<!-- STATS BAR -->
<div class="stats-bar">
  <div class="stat-item animate-fade">
    <div class="stat-num">20+</div>
    <div class="stat-label">Diverse AI Models</div>
  </div>
