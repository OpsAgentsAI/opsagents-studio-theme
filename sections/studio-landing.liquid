function renderModels() {
  const grid = document.getElementById('models-grid');
  models.forEach((m, i) => {
    const delay = Math.min(i * 0.04, 0.8);
    grid.innerHTML += `
      <div class="model-card animate-fade" style="animation-delay:${delay}s">
        <div class="model-avatar ${m.palette}">
          <div class="model-avatar-inner">
